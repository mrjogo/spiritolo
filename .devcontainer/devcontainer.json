{
  // Project name — adapt to match your project
  "name": "spiritolo",

  // Dockerfile build — shared across mixins that contribute to the Dockerfile
  "build": { "dockerfile": "Dockerfile" },

  "mounts": [
    // [repo-mixin:devcontainer-claude] Bind-mount host Claude Code config and SSH agent socket into the container.
    // Change target paths if your container user is not vscode.
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:XDG_RUNTIME_DIR:/run}/devcontainer-ssh-agent.sock,target=/tmp/ssh-agent.sock,type=bind"
    // [/repo-mixin:devcontainer-claude]
  ],

  "containerEnv": {
    // [repo-mixin:devcontainer-claude] Environment variables for Claude Code path bridging between host and container.
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "HOST_HOME": "${localEnv:HOME}",
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock",
    "CLAUDE_NOTIFY_HOST": "host.docker.internal"
    // [/repo-mixin:devcontainer-claude]
  },

  "initializeCommand": {
    // [repo-mixin:devcontainer-claude] capture-claude-env.sh runs on the HOST to write .env.devcontainer
    // with HOST_PROJECT_DIR and GH_TOKEN, which setup-claude-code.sh and gh consume inside the container.
    "claude-env": "bash .devcontainer/initializeCommand/capture-claude-env.sh"
  },
  // [repo-mixin:devcontainer-claude] Pass the .env.devcontainer file generated by capture-claude-env.sh
  // into the container as environment variables.
  "runArgs": ["--env-file", ".devcontainer/.env.devcontainer"],

  "remoteEnv": {
    // [repo-mixin:devcontainer-claude] Add ~/.local/bin to PATH for Claude Code binary
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
  },

  "features": {
    // [repo-mixin:devcontainer-claude] GitHub CLI — used for PR workflows and auth forwarding
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },

  // Post-create lifecycle hook — runs after container is created.
  // Each mixin adds its own named entry; the devcontainer runtime runs them in parallel.
  "postCreateCommand": {
    // [repo-mixin:devcontainer-claude] Bridge Claude Code paths between host and container
    "claude-code": "bash .devcontainer/postCreateCommand/setup-claude-code.sh",
    // [repo-mixin:devcontainer-python-uv] Sync uv environment from lockfile on container create.
    // Runs at repo root. If your pyproject.toml lives in a subdirectory, change to
    // "cd <subdir> && uv sync --frozen".
    "uv-sync": "cd scraper && uv sync --frozen"
  },

  // Post-start lifecycle hook — runs every time the container starts (not just on create).
  "postStartCommand": {
    // Forward Supabase-local ports from host.docker.internal to 127.0.0.1 so `supabase start`
    // (running in-container under docker-outside-of-docker) can reach its own services.
    "supabase-portforward": "bash .devcontainer/postStartCommand/supabase-port-forward.sh"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        // [repo-mixin:devcontainer-claude] Claude Code VS Code extension
        "anthropic.claude-code"
      ]
    }
  }
}
